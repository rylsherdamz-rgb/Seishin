{
  "expo": {
    "name": "Seishin",
    "slug": "seishin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "seishin",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.seishin.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.seishin.app",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-dev-client",
      "expo-mlkit-ocr",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Seishin to access your camera to scan schedules."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Seishin to access your photos for OCR scanning."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#000000"
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
